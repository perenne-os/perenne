# Normalize line endings: store text as LF in the repo, regardless of OS.
# Keeps a cross-platform kernel project consistent (Windows, Linux, macOS).
* text=auto eol=lf

# Windows-only scripts keep CRLF in the working tree.
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary file types (never normalize).
*.png binary
*.jpg binary
*.ico binary
*.bin binary
*.img binary
